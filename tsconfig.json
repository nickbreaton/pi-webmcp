{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Preserve",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noEmit": true,
    "types": [
      "node"
    ],
    "plugins": [
      {
        "name": "@effect/language-service"
      }
    ]
  },
  "include": [
    ".pi/extensions/**/*.ts",
    "src/**/*.ts"
  ]
}
