{
  "name": "pi-webmcp",
  "version": "0.2.0",
  "type": "module",
  "license": "MIT",
  "description": "A Pi extension that connects Pi to webpages that register WebMCP tools.",
  "author": "Nick Breaton <nick@nickbreaton.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nickbreaton/pi-webmcp.git"
  },
  "bugs": {
    "url": "https://github.com/nickbreaton/pi-webmcp/issues"
  },
  "homepage": "https://github.com/nickbreaton/pi-webmcp#readme",
  "keywords": [
    "pi-package",
    "pi-extension",
    "webmcp"
  ],
  "files": [
    "extensions/**",
    "src/**"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "fmt": "dprint fmt",
    "fmt:check": "dprint check",
    "prepack": "npm run typecheck && npm test && npm run fmt:check"
  },
  "dependencies": {
    "@effect/opentelemetry": "^4.0.0-beta.84",
    "@effect/platform-node": "4.0.0-beta.84",
    "@opentelemetry/exporter-trace-otlp-http": "^0.214.0",
    "chrome-remote-interface": "^0.33.3",
    "effect": "4.0.0-beta.84",
    "micro-memoize": "^5.1.1"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*",
    "typebox": "*"
  },
  "overrides": {
    "@kitlangton/motel": {
      "@effect/atom-react": "4.0.0-beta.49",
      "@effect/opentelemetry": "4.0.0-beta.49",
      "@effect/platform-bun": "4.0.0-beta.50",
      "@effect/platform-node-shared": "4.0.0-beta.50",
      "effect": "4.0.0-beta.49"
    }
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "^0.78.1",
    "@earendil-works/pi-tui": "^0.78.1",
    "@effect/language-service": "^0.86.2",
    "@effect/vitest": "4.0.0-beta.84",
    "@kitlangton/motel": "^0.2.5",
    "@opentelemetry/resources": "^2.8.0",
    "@opentelemetry/sdk-trace-web": "^2.8.0",
    "@types/chrome-remote-interface": "^0.34.0",
    "@types/node": "^25.9.2",
    "dprint": "^0.54.0",
    "typebox": "^1.2.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "pi": {
    "extensions": [
      "extensions/pi-webmcp.ts"
    ]
  }
}
