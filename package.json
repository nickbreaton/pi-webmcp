{
  "name": "pi-webmcp",
  "version": "0.1.0",
  "type": "module",
  "license": "MIT",
  "description": "A Pi extension that connects Pi to webpages that register WebMCP tools.",
  "keywords": [
    "pi-package",
    "pi-extension",
    "webmcp"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "fmt": "dprint fmt",
    "fmt:check": "dprint check"
  },
  "dependencies": {
    "@effect/language-service": "^0.86.2",
    "@effect/platform-node": "4.0.0-beta.84",
    "chrome-remote-interface": "^0.33.3",
    "effect": "4.0.0-beta.84",
    "micro-memoize": "^5.1.1"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*",
    "typebox": "*"
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "^0.78.1",
    "@earendil-works/pi-tui": "^0.78.1",
    "@effect/vitest": "4.0.0-beta.84",
    "@types/chrome-remote-interface": "^0.34.0",
    "@types/node": "^25.9.2",
    "dprint": "^0.54.0",
    "typebox": "^1.2.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "pi": {
    "extensions": [
      ".pi/extensions/pi-webmcp.ts"
    ]
  }
}
